<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:name=".SereneHealthApplication"
        android:allowBackup="true"
        android:label="Serene Health"
        android:supportsRtl="true"
        android:theme="@style/Theme.SereneHealth">

        <activity
            android:name=".activity.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.MessageCenterActivity"
            android:exported="false" />

        <activity
            android:name=".activity.SmartDiagnosisActivity"
            android:exported="false" />

        <activity
            android:name=".activity.DepartmentListActivity"
            android:exported="false" />
    </application>
</manifest>
