<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.SereneHealth.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary</item>
    </style>

    <style name="Widget.SereneHealth.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_container</item>
        <item name="android:textColor">@color/primary_container</item>
    </style>

    <style name="Widget.SereneHealth.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
    </style>

    <style name="TextAppearance.SereneHealth.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.SereneHealth.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.SereneHealth.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>
</resources>
