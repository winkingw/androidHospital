<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_arrow_back"
            android:background="@null"
            android:contentDescription="@string/action_back"
            android:padding="@dimen/spacing_small" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_small"
            android:text="@string/message_center_title"
            android:textSize="@dimen/text_size_title"
            android:textColor="@color/on_surface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_mark_all_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/message_center_mark_all_read"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/primary_container"
            android:padding="@dimen/spacing_small"
            android:background="@null"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- 消息分类标签 -->
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_small"
        android:paddingBottom="@dimen/spacing_small"
        android:background="@color/white"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tab_all"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_large"
            android:paddingEnd="@dimen/spacing_large"
            android:text="@string/message_center_tab_all"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/white"
            android:background="@drawable/shape_tab_selected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_system"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/spacing_small"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_large"
            android:paddingEnd="@dimen/spacing_large"
            android:text="@string/message_center_tab_system"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/on_surface_variant"
            android:background="@drawable/shape_tab_unselected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_appointment"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/spacing_small"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_large"
            android:paddingEnd="@dimen/spacing_large"
            android:text="@string/message_center_tab_appointment"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/on_surface_variant"
            android:background="@drawable/shape_tab_unselected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_other"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/spacing_small"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_large"
            android:paddingEnd="@dimen/spacing_large"
            android:text="@string/message_center_tab_other"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/on_surface_variant"
            android:background="@drawable/shape_tab_unselected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_variant" />

    <!-- RecyclerView 消息列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="@dimen/spacing_tiny"
        android:background="@color/surface" />

    <!-- 空视图 -->
    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/surface">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/message_center_empty"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/on_surface_variant" />

    </LinearLayout>

</LinearLayout>
