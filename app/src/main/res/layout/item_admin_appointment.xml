<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_medium"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="0dp"
    app:contentPadding="@dimen/card_padding"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1: Patient name + Status chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_patient_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.SereneHealth.Headline"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_medium"
                    android:paddingVertical="@dimen/spacing_tiny"
                    android:textAppearance="@style/TextAppearance.SereneHealth.Label"
                    android:textSize="@dimen/text_size_caption"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginBottom="@dimen/spacing_small"
            android:background="@color/outline_variant" />

        <!-- Row 2: Schedule date + Period -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/icon_size_small"
                android:layout_height="@dimen/icon_size_small"
                android:alpha="0.6"
                android:src="@drawable/ic_home_appointment"
                android:tint="@color/on_surface_variant" />

            <TextView
                android:id="@+id/tv_schedule_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.SereneHealth.Body"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_size_body" />
        </LinearLayout>

        <!-- Row 3: Department + Clinic room -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/icon_size_small"
                android:layout_height="@dimen/icon_size_small"
                android:alpha="0.6"
                android:src="@drawable/ic_medical_services"
                android:tint="@color/on_surface_variant" />

            <TextView
                android:id="@+id/tv_dept_clinic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.SereneHealth.Body"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_size_body" />
        </LinearLayout>

        <!-- Row 4: Appointment number (secondary) -->
        <TextView
            android:id="@+id/tv_appointment_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:textAppearance="@style/TextAppearance.SereneHealth.Label"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_size_caption" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:background="@color/outline_variant" />

        <TextView
            android:id="@+id/tv_feedback_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="患者评价"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_feedback_score"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_size_body" />

        <TextView
            android:id="@+id/tv_feedback_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_size_body" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
