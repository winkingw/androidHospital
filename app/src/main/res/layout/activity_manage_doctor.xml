<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:paddingTop="32dp"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_container"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_small"
        android:paddingEnd="@dimen/spacing_large">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_back"
            android:padding="@dimen/spacing_small"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_primary" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="医生管理"
            android:textColor="@color/on_primary"
            android:textSize="@dimen/text_size_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:padding="8dp"
            android:text="新增"
            android:textColor="@color/on_primary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Department Spinner with label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_large"
        android:paddingBottom="@dimen/spacing_small">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_small"
            android:text="选择科室"
            android:textAppearance="@style/TextAppearance.SereneHealth.Label"
            android:textColor="@color/on_surface_variant"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp"
            app:contentPadding="4dp">

            <Spinner
                android:id="@+id/sp_department"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Doctor List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_doctor_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_small"
        android:visibility="visible" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xlarge"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:importantForAccessibility="no"
            android:alpha="0.5"
            android:src="@drawable/ic_home_profile"
            android:tint="@color/outline_variant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:text="暂无医生信息"
            android:textAppearance="@style/TextAppearance.SereneHealth.Body"
            android:textColor="@color/on_surface_variant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:alpha="0.7"
            android:text="请先选择科室后再添加医生"
            android:textAppearance="@style/TextAppearance.SereneHealth.Label"
            android:textColor="@color/on_surface_variant" />
    </LinearLayout>

</LinearLayout>
